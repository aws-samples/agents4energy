{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "default",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "default"
  },
  "runtimes": [],
  "memories": [
    {
      "name": "MyHarnessMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaces": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaces": [
            "/users/{actorId}/preferences"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaces": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "EPISODIC",
          "namespaces": [
            "/episodes/{actorId}/{sessionId}"
          ],
          "reflectionNamespaces": [
            "/episodes/{actorId}"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "harnesses": [
    {
      "name": "MyHarness",
      "path": "app/MyHarness"
    }
  ],
  "datasets": []
}