{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "node",
    "composite": true,
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["es2021"],
    "paths": {
      "$amplify/*": [
        "../.amplify/generated/*"
      ],
      "@/*": ["../src/*"]
    }
  },
  "include": [
    "**/*.ts", 
    "../.amplify/generated/env/*.ts",
    "../src/utils/**/*.ts",
    "../amplify_outputs.json"
  ]
}